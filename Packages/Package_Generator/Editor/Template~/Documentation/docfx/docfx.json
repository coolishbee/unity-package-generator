{
  "metadata": [
    {
      "src": [
        {
          "src": "../../SampleProjects/project-file-path/",
          "files": [
            "corresponding-package-project.csproj"
          ]
        }
      ],
      "dest": "api"
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "**/*.{md,yml}"
        ],
        "exclude": [
          "_site/**"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**"
        ],
        "exclude": [
          "_site/**",
          "docs/**"
        ]
      }
    ],
    "output": "_site",
    "template": [
      "default",
      ".docfx/template"
    ],
    "globalMetadata": {
      "_appName": "PackageName",
      "_appTitle": "PackageName",
      "_appLogoPath": "images/logo.png",
      "_appFaviconPath": "images/favicon.ico",
      "_enableSearch": true,
      "_enableNewTab": true
    },
    "markdownEngineName": "markdig",
    "markdownEngineProperties": {
      "markdigExtensions": [
        "tasklists",
        "diagrams"
      ]
    }
  }
}
